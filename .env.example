# Copy this to .env and fill in the values

# WebSocket URL of your PowerGuardian controller
# Use the IP address — powerguardian.local does not resolve inside Docker
PG_CONTROLLER_URL=ws://10.0.0.40:8181/agent

# Agent token from the controller adoption page (Settings → Connectors → Add)
PG_AGENT_KEY=changeme

# Watchtower token — pick any random string, must match in both services
PG_WATCHTOWER_TOKEN=pg-connector-token
